use nf_vault::Vault;
use serde::{Deserialize, Serialize};

#[derive(Serialize, Deserialize)]
struct FileEntry {
    path: String,
    is_dir: bool,
    size: u64,
}

#[derive(Serialize, Deserialize)]
struct NoteInfo {
    path: String,
    content: String,
    html: String,
    frontmatter: String,
    links: Vec<LinkInfo>,
    tags: Vec<String>,
    backlinks: Vec<String>,
    word_count: usize,
}

#[derive(Serialize, Deserialize)]
struct LinkInfo {
    target: String,
    display: Option<String>,
    subpath: Option<String>,
}

#[derive(Serialize, Deserialize)]
struct SearchResult {
    path: String,
    excerpt: String,
}

#[derive(Serialize, Deserialize)]
struct GraphData {
    nodes: Vec<GraphNode>,
    edges: Vec<GraphEdge>,
}

#[derive(Serialize, Deserialize)]
struct GraphNode {
    id: usize,
    title: String,
    link_count: usize,
}

#[derive(Serialize, Deserialize)]
struct GraphEdge {
    source: usize,
    target: usize,
}

// ── Tauri Commands ──────────────────────────────────────────────────

#[tauri::command]
fn open_vault(path: &str) -> Result<Vec<FileEntry>, String> {
    let vault = Vault::open(std::path::Path::new(path)).map_err(|e| e.to_string())?;
    let tree = vault.file_tree().map_err(|e| e.to_string())?;
    Ok(tree.iter().map(|e| FileEntry {
        path: e.path.clone(),
        is_dir: e.is_dir,
        size: e.size,
    }).collect())
}

#[tauri::command]
fn read_note(vault_path: &str, note_path: &str) -> Result<NoteInfo, String> {
    let vault = Vault::open(std::path::Path::new(vault_path)).map_err(|e| e.to_string())?;
    let content = vault.read_note(note_path).map_err(|e| e.to_string())?;
    let text = String::from_utf8_lossy(&content).to_string();
    let meta = nf_markdown::parse_to_meta(note_path, &content);

    // Generate HTML using comrak with GFM via nf-render
    let comrak_html = nf_render::render_html(&text);

    let frontmatter_json = serde_json::to_string(&meta.frontmatter.fields).unwrap_or_default();

    // Backlinks
    let all_metas = scan_all_metas(&vault, note_path);
    let backlinks: Vec<String> = all_metas.iter()
        .filter(|(p, m)| *p != note_path && m.links_out.iter().any(|l| l.target == note_path.trim_end_matches(".md")))
        .map(|(p, _)| p.clone())
        .collect();

    let text_content = text.clone();
    let words_count = text.split_whitespace().count();

    Ok(NoteInfo {
        path: note_path.to_string(),
        content: text_content,
        html: comrak_html,
        frontmatter: frontmatter_json,
        links: meta.links_out.iter().map(|l| LinkInfo {
            target: l.target.clone(),
            display: l.display.clone(),
            subpath: l.subpath.clone(),
        }).collect(),
        tags: meta.tags_inline.iter().map(|t| t.tag.clone()).collect(),
        backlinks,
        word_count: words_count,
    })
}

#[tauri::command]
fn search_notes(vault_path: &str, query: &str) -> Result<Vec<SearchResult>, String> {
    let vault = Vault::open(std::path::Path::new(vault_path)).map_err(|e| e.to_string())?;
    let tree = vault.file_tree().map_err(|e| e.to_string())?;
    let q = query.to_lowercase();
    let mut results = Vec::new();

    for entry in &tree {
        if !entry.path.ends_with(".md") { continue; }
        if let Ok(content) = vault.read_note(&entry.path) {
            let text = String::from_utf8_lossy(&content);
            if text.to_lowercase().contains(&q) {
                let excerpt = text.lines()
                    .find(|l| l.to_lowercase().contains(&q))
                    .unwrap_or("")
                    .to_string();
                results.push(SearchResult {
                    path: entry.path.clone(),
                    excerpt,
                });
                if results.len() >= 50 { break; }
            }
        }
    }
    Ok(results)
}

#[tauri::command]
fn get_graph(vault_path: &str) -> Result<GraphData, String> {
    let vault = Vault::open(std::path::Path::new(vault_path)).map_err(|e| e.to_string())?;
    let tree = vault.file_tree().map_err(|e| e.to_string())?;

    let mut metas = Vec::new();
    for entry in &tree {
        if !entry.path.ends_with(".md") { continue; }
        if let Ok(content) = vault.read_note(&entry.path) {
            metas.push(nf_markdown::parse_to_meta(&entry.path, &content));
        }
    }

    let graph = nf_graph::NoteGraph::build(&metas);
    Ok(GraphData {
        nodes: graph.nodes.iter().map(|n| GraphNode {
            id: n.id,
            title: n.title.clone(),
            link_count: n.link_count,
        }).collect(),
        edges: graph.edges.iter().map(|e| GraphEdge {
            source: e.source,
            target: e.target,
        }).collect(),
    })
}

fn scan_all_metas(vault: &Vault, _current: &str) -> Vec<(String, nf_core::note::NoteMeta)> {
    let mut metas = Vec::new();
    if let Ok(tree) = vault.file_tree() {
        for entry in &tree {
            if !entry.path.ends_with(".md") { continue; }
            if let Ok(content) = vault.read_note(&entry.path) {
                let meta = nf_markdown::parse_to_meta(&entry.path, &content);
                metas.push((entry.path.clone(), meta));
            }
        }
    }
    metas
}

#[tauri::command]
fn list_profiles() -> Vec<String> {
    nf_vaultgen::profiles::list_builtin_profiles().into_iter().map(|s| s.to_string()).collect()
}

#[tauri::command]
fn generate_vault(profile: &str, seed: u64, out: &str) -> Result<String, String> {
    let summary = nf_vaultgen::generate(profile, seed, std::path::Path::new(out))
        .map_err(|e| e.to_string())?;
    Ok(format!("生成完成: {} 篇笔记, {} 个链接", summary.counts.notes, summary.counts.links_total))
}

#[tauri::command]
fn write_note(vault_path: &str, note_path: &str, content: &str) -> Result<(), String> {
    let vault = nf_vault::Vault::open(std::path::Path::new(vault_path)).map_err(|e| e.to_string())?;
    vault.write_note(note_path, content.as_bytes()).map_err(|e| e.to_string())
}

#[tauri::command]
fn create_note(vault_path: &str, note_path: &str) -> Result<(), String> {
    let vault = nf_vault::Vault::open(std::path::Path::new(vault_path)).map_err(|e| e.to_string())?;
    vault.create_note(note_path).map_err(|e| e.to_string())
}

#[tauri::command]
fn delete_note(vault_path: &str, note_path: &str) -> Result<(), String> {
    let vault = nf_vault::Vault::open(std::path::Path::new(vault_path)).map_err(|e| e.to_string())?;
    vault.delete_note(note_path).map_err(|e| e.to_string())
}

fn render_markdown(content: &str) -> String {
#[tauri::command]
fn vault_stats(vault_path: &str) -> Result<String, String> {
    let vault = nf_vault::Vault::open(std::path::Path::new(vault_path)).map_err(|e| e.to_string())?;
    let tree = vault.file_tree().map_err(|e| e.to_string())?;
    let notes = tree.iter().filter(|e| !e.is_dir && e.path.ends_with(".md")).count();
    let attachments = tree.iter().filter(|e| !e.is_dir && !e.path.ends_with(".md")).count();
    let dirs = tree.iter().filter(|e| e.is_dir).count();
    let total_size: u64 = tree.iter().filter(|e| !e.is_dir).map(|e| e.size).sum();
    Ok(format!("Vault统计: {}笔记 {}附件 {}目录 {}KB", notes, attachments, dirs, total_size / 1024))
}

    nf_render::render_html(content)
}

#[tauri::command]
fn render_note(vault_path: &str, note_path: &str) -> Result<String, String> {
    let vault = nf_vault::Vault::open(std::path::Path::new(vault_path)).map_err(|e| e.to_string())?;
    vault.read_note(note_path).map_err(|e| e.to_string())
        .map(|content| nf_render::render_html(&String::from_utf8_lossy(&content)))
}

fn main() {
    tauri::Builder::default()
        .plugin(tauri_plugin_shell::init())
        .plugin(tauri_plugin_dialog::init())
        .invoke_handler(tauri::generate_handler![
            open_vault,
            write_note,
            create_note,
            delete_note,
            vault_stats,
            render_markdown,
            render_note,
            read_note,
            search_notes,
            get_graph,
            list_profiles,
            generate_vault,
        ])
        .run(tauri::generate_context!())
        .expect("error while running tauri application");
}
